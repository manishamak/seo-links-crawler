{
	"name": "slc/seo-links-crawler",
	"description": "Crawl home page and display all internal links on admin page and in sitemap.html",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "Manisha Makhija",
			"email": "manisham2507@gmail.com"
		}
	],
	"type": "wordpress-plugin",
	"require": {
		"php": ">=8.3"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require-dev": {
		"brain/monkey": "^2.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/phpcompatibility-wp": "^2.0",
		"phpunit/phpunit": "^11.0",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"Slc\\SeoLinksCrawler\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Slc\\SeoLinksCrawler\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test-unit": "phpunit --testsuite unit",
		"phpcs": "phpcs --basepath=. src templates seo-links-crawler.php",
		"phpcs:fix": "phpcbf --basepath=. src templates seo-links-crawler.php"
	}
}
